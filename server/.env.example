# Server
PORT=5000
SECRETE_KEY=your_jwt_secret
JWT_EXPIRES=7d

# MongoDB
MONGO_URI=your_mongodb_connection_string

# CORS — comma-separated allowed frontend origins
CLIENT_ORIGINS=https://social-network-fronted.onrender.com,http://localhost:5173,http://127.0.0.1:5173
CLIENT_URL=https://social-network-fronted.onrender.com

# Optional
APP_NAME=Sanjal
API_RATE_WINDOW_MS=60000
API_RATE_MAX=200
